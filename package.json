{
  "private": true,
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "dev": "concurrently -n ui,api -c green,cyan \"npm run dev:ui\" \"npm run dev:api\"",
    "dev:ui": "npm --prefix tbt-paper-terminal-main run dev --",
    "dev:api": "npm --prefix tbt-paper-terminal-main run server --",
    "server": "npm --prefix tbt-paper-terminal-main run server",
    "build": "npm --prefix tbt-paper-terminal-main run build --",
    "preview": "npm --prefix tbt-paper-terminal-main run preview --",
    "test": "npm --prefix tbt-paper-terminal-main run test --"
  }
}
